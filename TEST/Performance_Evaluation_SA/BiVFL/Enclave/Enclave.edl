enclave {
    from "sgx_tstdc.edl" import *;
    
    trusted {
        public void ecall_prepare_gradient(
            int client_id, int proj_seed, int param_size, 
            [in, count=param_size] const float* w_new, 
            [in, count=param_size] const float* w_old_cache, 
            [out, count=1024] float* out_proj
        );

        /* 升级为最新全局+自掩码接口，并传入 w_new 模拟真实访存 */
        public void ecall_generate_masked_gradient_sparse(
            [in, string] const char* kappa_m_str, int t, [in, string] const char* model_hash_str,
            int client_id, [in, count=param_size] const float* w_new, float weight,
            int param_size, [out, count=param_size] int64_t* out_masked_gradient
        );

        /* 升级为最新打标签 View-Binding SSS 接口 */
        public void ecall_get_scalar_shares_sparse(
            [in, string] const char* kappa_s_str, [in, string] const char* kappa_m_str,
            int t, [in, string] const char* view_hash_str, int client_id,
            [in, count=num_alive] const int* alive_neighbors, int num_alive,
            [in, count=num_dropped] const int* dropped_neighbors, int num_dropped,
            int threshold, [out, count=max_len] int64_t* out_shares, size_t max_len
        );
    };

    untrusted {
        void ocall_print_string([in, string] const char *str);
    };
};